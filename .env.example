# ============================================================
# PDF 合并工具 - 环境变量模板
#
# 复制此文件为 .env 并填写实际值
# 注意：.env 文件已在 .gitignore 中排除，不会被提交到仓库
# ============================================================

# Tauri 更新签名私钥（用于自动更新功能，可选）
# TAURI_SIGNING_PRIVATE_KEY=

# Tauri 更新签名密码（可选）
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# GitHub Token（CI/CD 中使用 GitHub Secrets 管理，本地开发无需配置）
# GITHUB_TOKEN=

